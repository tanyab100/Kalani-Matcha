{
  "name": "matcha-ordering-app-root",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "lint": "eslint 'client/src/**/*.{ts,tsx}' 'backend/src/**/*.ts'",
    "format": "prettier --write 'client/src/**/*.{ts,tsx}' 'backend/src/**/*.ts'",
    "format:check": "prettier --check 'client/src/**/*.{ts,tsx}' 'backend/src/**/*.ts'",
    "test:frontend": "cd client && npm test",
    "test:backend": "cd backend && npm test",
    "test": "npm run test:frontend && npm run test:backend"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3"
  }
}
